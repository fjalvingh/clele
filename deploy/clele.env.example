# Copy to /etc/clele/clele.env on the server and fill in real values, then `chmod 600` it.
# Read by the systemd unit (EnvironmentFile). Keep this file OFF the public web and out of git.

SPRING_PROFILES_ACTIVE=prod

# PostgreSQL on the server (the prod profile defaults DB_URL/DB_USER to these if unset).
DB_URL=jdbc:postgresql://localhost:5432/partsdb
DB_USER=partsuser
DB_PASSWORD=change-me

# Anthropic API key for AI part search (leave blank to disable AI features).
ANTHROPIC_API_KEY=sk-ant-...
